{
  "name": "@mikavilpas/oxfmt-config",
  "version": "3.0.2",
  "description": "The oxfmt config Mika Vilpas uses in personal projects.",
  "keywords": [
    "config",
    "formatter",
    "oxfmt"
  ],
  "homepage": "https://github.com/mikavilpas/mika-config/tree/main/packages/oxfmt-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikavilpas/mika-config.git",
    "directory": "packages/oxfmt-config"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./oxfmt.config.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/oxfmt.config.d.ts",
        "import": "./dist/oxfmt.config.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "rm -f ./*.tgz && tsc && pnpm pack && attw ./*.tgz; status=$?; rm -f ./*.tgz; exit $status",
    "prepack": "tsc"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "oxfmt": "catalog:"
  },
  "peerDependencies": {
    "oxfmt": "^0.59.0"
  }
}
