{
  "name": "@mikavilpas/mika-config",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter oxfmt-config --filter oxlint-config build && pnpm build:renovate-config",
    "build:renovate-config": "tsc --noEmit",
    "lint": "pnpx oxlint",
    "test": "vitest",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@mikavilpas/oxfmt-config": "workspace:*",
    "@mikavilpas/oxlint-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "re2": "catalog:",
    "syncpack": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.15.0"
}
