{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": ["config:best-practices", "group:allNonMajor"],
  "commitBodyTable": true,
  "packageRules": [
    {
      "description": ["Automerge digest updates weekly"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "schedule": ["before 9am on monday"]
    }
  ],
  "customManagers": [
    {
      "description": [
        "Update github-releases in yml/lua files. Examples:",
        "- `# renovate: datasource=github-releases depName=X`",
        "- `-- renovate: datasource=github-releases depName=X`"
      ],
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": ["**/*.yml", "**/*.lua"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=github-releases\\s+depName=(?<depName>\\S+)\\s*[\\r\\n]+[^:]+:\\s*\"?(?<currentValue>[^\",\\s]+)\"?",
        "-- renovate: datasource=github-releases depName=(?<depName>[^\\s]+)[\\s\\S]*?version\\s*=\\s*\"?(?<currentValue>[^\",]+)\"?"
      ]
    },
    {
      "description": [
        "Track git-refs on main branch in yml/lua files. Examples:",
        "- `# renovate: datasource=git-refs packageName=X`",
        "- `-- renovate: datasource=git-refs packageName=X`"
      ],
      "customType": "regex",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "main",
      "managerFilePatterns": ["**/*.yml", "**/*.lua"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=git-refs\\s+packageName=(?<packageName>\\S+)\\s*[\\r\\n]+[^:]+:\\s*\"?(?<currentDigest>[^\",\\s]+)\"?",
        "-- renovate: datasource=git-refs packageName=(?<packageName>[^\\s]+)\\s*?commit = \"?(?<currentDigest>[^\",]+)\"?"
      ]
    },
    {
      "description": [
        "Track git-refs on master branch in yml/lua files. Examples:",
        "- `# renovate: datasource=git-refs-master packageName=X`",
        "- `-- renovate: datasource=git-refs-master packageName=X`"
      ],
      "customType": "regex",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "master",
      "managerFilePatterns": ["**/*.yml", "**/*.lua"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=git-refs-master\\s+packageName=(?<packageName>\\S+)\\s*[\\r\\n]+[^:]+:\\s*\"?(?<currentDigest>[^\",\\s]+)\"?",
        "-- renovate: datasource=git-refs-master packageName=(?<packageName>[^\\s]+)\\s*?commit = \"?(?<currentDigest>[^\",]+)\"?"
      ]
    },
    {
      "description": [
        "Update npm packages in GitHub Action workflow env vars. Example:",
        "- `# renovate: datasource=npm depName=X`",
        "Useful for semantic-release which recommends CI-only installation."
      ],
      "customType": "regex",
      "datasourceTemplate": "npm",
      "managerFilePatterns": [".github/workflows/*.yml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=npm\\s+depName=(?<depName>\\S+)\\s*[\\r\\n]+\\s*[A-Z_]+:\\s*\"?(?<currentValue>[^\",\\s]+)\"?"
      ]
    },
    {
      "description": [
        "Update git tag versions in yml files such as GitHub actions and workflows. Example:",
        "- `# renovate: datasource=git-tags packageName=X`"
      ],
      "customType": "regex",
      "datasourceTemplate": "git-tags",
      "managerFilePatterns": ["**/*.yml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=git-tags\\s+packageName=(?<packageName>\\S+)\\s*[\\r\\n]+\\s*\\w+:\\s*\"?(?<currentValue>[^\",\\s]+)\"?"
      ]
    },
    {
      "description": [
        "Update crate versions in toml files. Example:",
        "- `# renovate: datasource=crate depName=bacon`",
        "- `\"cargo:bacon\" = \"3.22.0\"`",
        "Useful for cargo tools in mise config where the built-in mise manager doesn't update cargo: backend tools."
      ],
      "customType": "regex",
      "datasourceTemplate": "crate",
      "managerFilePatterns": ["**/*.toml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=crate\\s+depName=(?<depName>\\S+)\\s*[\\r\\n]+[^=]+=\\s*\"?(?<currentValue>[^\",\\s]+)\"?"
      ]
    },
    {
      "description": [
        "Update npm packages in toml files. Example:",
        "- `# renovate: datasource=npm depName=@anthropic-ai/claude-code`",
        "- `\"aqua:anthropics/claude-code\" = \"2.1.117\"`",
        "Useful for aqua tools whose registry uses http package type, which the built-in mise manager doesn't support."
      ],
      "customType": "regex",
      "datasourceTemplate": "npm",
      "managerFilePatterns": ["**/*.toml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=npm\\s+depName=(?<depName>\\S+)\\s*[\\r\\n]+[^=]+=\\s*\"?(?<currentValue>[^\",\\s]+)\"?"
      ]
    }
  ]
}
